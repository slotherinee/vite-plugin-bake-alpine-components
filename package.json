{
  "name": "vite-plugin-bake-alpine-components",
  "version": "0.3.1",
  "description": "Vite plugin that bakes Alpine.js components and directives into static HTML at build time",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "src",
    "index.d.ts",
    "README.md"
  ],
  "keywords": [
    "vite",
    "vite-plugin",
    "alpine",
    "alpinejs",
    "static-site",
    "ssg",
    "html",
    "components"
  ],
  "author": "Pavel Tarasov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/slotherinee/vite-plugin-bake-alpine-components"
  },
  "homepage": "https://github.com/slotherinee/vite-plugin-bake-alpine-components#readme",
  "bugs": {
    "url": "https://github.com/slotherinee/vite-plugin-bake-alpine-components/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "dependencies": {
    "prettier": "^3.0.0"
  }
}
